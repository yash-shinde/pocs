{
  "uid": "resilient-orders-overview",
  "title": "Resilient Orders Overview",
  "tags": ["spring", "orders", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "style": "dark",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "editable": false,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "stat",
      "title": "Order Place Success",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(orders_operation_success_total{operation=\"order.place\"})",
          "legendFormat": "success"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Inventory Failures",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(orders_operation_failure_total{operation=\"inventory.reserve\"})",
          "legendFormat": "failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Notification Failures",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(orders_operation_failure_total{operation=\"notification.send\"})",
          "legendFormat": "failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Operation Duration",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "rate(orders_operation_duration_seconds_sum[1m]) / rate(orders_operation_duration_seconds_count[1m])",
          "legendFormat": "avg duration"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    }
  ]
}
